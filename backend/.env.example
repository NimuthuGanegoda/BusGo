# ============================================================
#  BusGo Backend — Environment Variables
#  Copy this file to .env and fill in your real values.
#  NEVER commit .env to git.
# ============================================================

# ── Server ───────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_STORAGE_AVATARS_BUCKET=avatars

# ── JWT Secrets ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string_minimum_32_chars
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string_here
JWT_RESET_SECRET=replace_with_another_different_64_char_random_hex_string

# Token lifetimes (in seconds)
JWT_ACCESS_EXPIRES_IN=900        # 15 minutes
JWT_REFRESH_EXPIRES_IN=604800    # 7 days
JWT_RESET_EXPIRES_IN=300         # 5 minutes

# ── Security ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_AUTH_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_AUTH_MAX=10             # 10 auth attempts per window
RATE_LIMIT_GENERAL_WINDOW_MS=60000 # 1 minute
RATE_LIMIT_GENERAL_MAX=100         # 100 requests per minute

# ── QR Token ─────────────────────────────────────────────────
QR_TOKEN_EXPIRES_SECONDS=30

# ── Password Reset PIN ────────────────────────────────────────
RESET_PIN_EXPIRES_MINUTES=10

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
# Add your React admin URL and any other origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── ML Microservice ───────────────────────────────────────────
# URL of the Python Flask ML service
ML_SERVICE_URL=http://localhost:8000
# In Docker: ML_SERVICE_URL=http://ml_service:8000
